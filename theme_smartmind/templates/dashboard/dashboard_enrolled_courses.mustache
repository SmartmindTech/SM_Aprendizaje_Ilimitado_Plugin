{{!
    @template theme_smartmind/dashboard/dashboard_enrolled_courses

    SmartMind Dashboard — "Seguir aprendiendo" section.
    Full-width 3-column grid of course cards with progress rings.
}}
<div class="catalog-section catalog-section--enrolled">
    <div class="catalog-section__header">
        <div>
            <h5 class="catalog-section__title"><i class="fas fa-book catalog-section__icon catalog-section__icon--green"></i> {{#str}}dashboard_seguir, theme_smartmind{{/str}}</h5>
            <p class="catalog-section__desc">{{#str}}dashboard_seguir_desc, theme_smartmind{{/str}}</p>
        </div>
        <a href="#" class="catalog-section__viewall">{{#str}}dashboard_viewall_courses, theme_smartmind{{/str}}</a>
    </div>
    <div class="catalog-section__content">
        {{#hasenrolledcourses}}
        <div class="dashboard-course-grid">
            {{#enrolledcourses}}
                {{> theme_smartmind/dashboard/dashboard_course_card }}
            {{/enrolledcourses}}
        </div>
        {{/hasenrolledcourses}}
        {{^hasenrolledcourses}}
        <div class="catalog-section__empty">
            {{#str}}continuelearning_placeholder, theme_smartmind{{/str}}
        </div>
        {{/hasenrolledcourses}}
    </div>
</div>
