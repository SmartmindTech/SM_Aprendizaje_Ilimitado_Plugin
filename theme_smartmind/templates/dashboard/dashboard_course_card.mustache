{{! @source: layout/mydashboard.php > classes/dashboard_helper.php::build_course_base() }}
{{!
    @template theme_smartmind/dashboard/dashboard_course_card

    SmartMind Dashboard — Course card.
    White bg, image with diffuse, play button on hover, progress ring, title + subtitle.
}}
<article class="course-card {{#hasprogress}}course-card--enrolled{{/hasprogress}}" data-course-id="{{{id}}}">
    <a href="{{#hasprogress}}{{resumeurl}}{{/hasprogress}}{{^hasprogress}}{{viewurl}}{{/hasprogress}}" class="course-card__thumb">
        {{#courseimage}}
        <img src="{{courseimage}}" class="course-card__thumb-img" alt="{{fullname}}" loading="lazy">
        {{/courseimage}}
        {{^courseimage}}
        <img src="https://picsum.photos/seed/course{{{id}}}/600/340" class="course-card__thumb-img" alt="{{fullname}}" loading="lazy">
        {{/courseimage}}
        <div class="course-card__diffuse"></div>

        {{#hasprogress}}
        <div class="course-card__play">
            <i class="fa fa-play"></i>
        </div>
        {{/hasprogress}}
    </a>
    <div class="course-card__body">
        <div class="course-card__text">
            <h3 class="course-card__title"><a href="{{viewurl}}">{{fullname}}</a></h3>
            {{#hascategory}}<span class="course-card__subtitle">{{categoryname}}</span>{{/hascategory}}
        </div>
        {{#hasprogress}}
        <div class="course-card__ring" data-progress="{{progress}}">
            <svg viewBox="0 0 36 36" class="course-card__ring-svg">
                <circle class="course-card__ring-bg" cx="18" cy="18" r="15.9"></circle>
                <circle class="course-card__ring-fill" cx="18" cy="18" r="15.9"
                        stroke-dasharray="{{progress}}, 100"></circle>
            </svg>
            <span class="course-card__ring-pct">{{progress}}%</span>
        </div>
        {{/hasprogress}}
    </div>
</article>
