{{!
    @template theme_smartmind/dashboard/dashboard_scrollable_vertical

    SmartMind Dashboard — Reusable vertical scrollable list.
    Parent template for block inheritance. Override the scroll_items block
    with your card markup.
}}
<div class="smartmind-scroll smartmind-scroll--vertical {{$scroll_extra_class}}{{/scroll_extra_class}}" data-region="smartmind-scroll">
    <button class="smartmind-scroll__btn smartmind-scroll__btn--up" data-action="scroll-prev" aria-label="Previous">
        <i class="fa fa-chevron-up"></i>
    </button>
    <div class="smartmind-scroll__track" data-region="scroll-track">
        {{$scroll_items}}{{/scroll_items}}
    </div>
    <button class="smartmind-scroll__btn smartmind-scroll__btn--down" data-action="scroll-next" aria-label="Next">
        <i class="fa fa-chevron-down"></i>
    </button>
</div>
