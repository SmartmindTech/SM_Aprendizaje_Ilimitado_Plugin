{{!
    @template theme_smartmind/dashboard/dashboard_completed_courses

    SmartMind Dashboard — Completed courses section.
    Catalog-style section with header, "view all" link, and horizontal scroll.
}}
<div class="catalog-section catalog-section--completed">
    <div class="catalog-section__header">
        <h5 class="catalog-section__title">{{#str}}dashboard_completed, theme_smartmind{{/str}}</h5>
        <a href="#" class="catalog-section__viewall">{{#str}}dashboard_viewall, theme_smartmind{{/str}}</a>
    </div>
    <div class="catalog-section__content">
        {{#hascompletedcourses}}
        {{< theme_smartmind/dashboard/dashboard_scrollable_horizontal }}
            {{$scroll_extra_class}}{{#completedcoursesscrollable}}has-overflow{{/completedcoursesscrollable}}{{/scroll_extra_class}}
            {{$scroll_items}}
                {{#completedcourses}}
                    {{> theme_smartmind/dashboard/dashboard_course_card }}
                {{/completedcourses}}
            {{/scroll_items}}
        {{/ theme_smartmind/dashboard/dashboard_scrollable_horizontal }}
        {{/hascompletedcourses}}
        {{^hascompletedcourses}}
        <div class="catalog-section__empty">
            {{#str}}dashboard_section_placeholder, theme_smartmind{{/str}}
        </div>
        {{/hascompletedcourses}}
    </div>
</div>
