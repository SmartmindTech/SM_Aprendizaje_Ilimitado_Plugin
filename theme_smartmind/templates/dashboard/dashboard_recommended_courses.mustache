{{! @source: layout/mydashboard.php > classes/dashboard_helper.php::get_fake_recommended_courses() }}
{{!
    @template theme_smartmind/dashboard/dashboard_recommended_courses

    SmartMind Dashboard — Recommended courses section.
    Horizontal row of cards with category badges, diffuse overlay, and metadata.
}}
<div class="catalog-section catalog-section--recommended">
    <div class="catalog-section__header">
        <div>
            <h5 class="catalog-section__title"><i class="fas fa-star catalog-section__icon catalog-section__icon--green"></i> {{#str}}dashboard_recommended, theme_smartmind{{/str}}</h5>
            <p class="catalog-section__desc">{{#str}}dashboard_recommended_desc, theme_smartmind{{/str}}</p>
        </div>
        <a href="{{catalogurl}}" class="catalog-section__viewall">{{#str}}dashboard_viewall, theme_smartmind{{/str}}</a>
    </div>
    <div class="catalog-section__content">
        {{#hasrecommendedcourses}}
        <div class="dashboard-recommended-grid">
            {{#recommendedcourses}}
            <article class="recommended-card" data-course-id="{{{id}}}">
                <a href="{{viewurl}}" class="recommended-card__thumb">
                    {{#courseimage}}
                    <img src="{{courseimage}}" class="recommended-card__thumb-img" alt="{{fullname}}" loading="lazy">
                    {{/courseimage}}
                    {{^courseimage}}
                    <img src="https://picsum.photos/seed/rec{{{id}}}/600/400" class="recommended-card__thumb-img" alt="{{fullname}}" loading="lazy">
                    {{/courseimage}}
                    <div class="recommended-card__diffuse"></div>
                </a>
                <div class="recommended-card__info">
                    {{#hascategory}}
                    <span class="recommended-card__badge">{{categoryname}}</span>
                    {{/hascategory}}
                    <h3 class="recommended-card__title">
                        <a href="{{viewurl}}">{{fullname}}</a>
                    </h3>
                    <div class="recommended-card__meta">
                        <span><i class="fa fa-users"></i> {{studentcount}}</span>
                        <span><i class="fa fa-book"></i> {{activitycount}}</span>
                    </div>
                </div>
            </article>
            {{/recommendedcourses}}
        </div>
        {{/hasrecommendedcourses}}
        {{^hasrecommendedcourses}}
        <div class="catalog-section__empty">
            {{#str}}dashboard_section_placeholder, theme_smartmind{{/str}}
        </div>
        {{/hasrecommendedcourses}}
    </div>
</div>
