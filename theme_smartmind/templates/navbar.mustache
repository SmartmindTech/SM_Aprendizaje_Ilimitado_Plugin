{{!

    @template theme_smartmind/navbar

    This template renders the top navbar.

    Example context (json):
    {
        "output": {
            "should_display_navbar_logo": true,
            "get_compact_logo_url": "http://placekitten.com/50/50",
            "custom_menu": "<li>..</li>",
            "page_heading_menu": "<li>..</li>",
            "search_box": "<div><input type='text'></div>",
            "navbar_plugin_output": "<div class='dropdown'>Messaging</div>",
            "user_menu": "<div class='dropdown'>John Doe</div>"
        },
        "config": {
            "wwwroot": "#",
            "homeurl": "/my/"
        },
        "sitename": "Moodle Site",
        "mobileprimarynav": [
            {
                "text": "Dashboard",
                "url": "/my",
                "isactive": true
            },
            {
                "text": "Site home",
                "url": "/",
                "isactive": false
            },
            {
                "text": "My courses",
                "url": "/course",
                "isactive": false
            }
        ]
    }
}}
<nav class="d-flex" aria-label="{{#str}}sitemenubar, admin{{/str}}">
    <div class="d-flex justify-content-between flex-grow-1">
        <button class="navbar-toggler aabtn d-block d-md-none px-1 my-1 border-0" data-toggler="drawers" data-action="toggle" data-target="theme_smartmind-drawers-primary">
            <span class="navbar-toggler-icon"></span>
            <span class="visually-hidden">{{#str}}sidepanel, core{{/str}}</span>
        </button>
        <div class="d-flex flex-column gap-4 justify-content-center p-4">
            <a href="{{{ config.homeurl }}}">

                {{# output.should_display_navbar_logo }}
                    <img src="{{output.get_compact_logo_url}}" class="logo me-1" alt="{{sitename}}">
                {{/ output.should_display_navbar_logo }}
                {{^ output.should_display_navbar_logo }}
                    {{{ sitename }}}
                {{/ output.should_display_navbar_logo }}
            </a>
            {{#primarymoremenu}}
                <div class="primary-navigation">
                    <ul class="d-flex flex-column list-unstyled">
                        {{#nodecollection}}
                            {{#children}}
                                {{> core/moremenu_children}}
                            {{/children}}
                        {{/nodecollection}}
                        {{#nodearray}}
                            {{> core/moremenu_children}}
                        {{/nodearray}}
                    </ul>
                </div>
            {{/primarymoremenu}}
        </div>

        <ul class="navbar-nav d-none d-md-flex my-1 px-1">
            <!-- page_heading_menu -->
            {{{ output.page_heading_menu }}}
        </ul>

        <div id="usernavigation" class="d-flex align-items-center mt-2 gap-3">
            {{# output.search_box }}
                {{{ output.search_box }}}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/output.search_box}}
            {{#langmenu}}
                {{> theme_smartmind/language_menu }}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/langmenu}}
            {{{ output.navbar_plugin_output }}}
            <div class="d-flex align-items-stretch usermenu-container" data-region="usermenu">
                {{#usermenu}}
                    {{> core/user_menu }}
                {{/usermenu}}
            </div>
            {{{ output.edit_switch }}}
        </div>
    </div>
</nav>

{{> theme_smartmind/primary-drawer-mobile }}
