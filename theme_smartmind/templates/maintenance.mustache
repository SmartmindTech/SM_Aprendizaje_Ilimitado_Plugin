{{!
    @template theme_smartmind/maintenance

    Boost maintenance layout template.

    Context variables required for this template:
    * output - The core renderer for the page

    Example context (json):
    {
        "output": {
            "doctype": "<!DOCTYPE html>",
            "page_title": "Test page",
            "favicon": "favicon.ico",
            "main_content": "<h1>Headings make html validators happier</h1>"
         }
    }
}}
{{{ output.doctype }}}
<html {{{ output.htmlattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body {{{ output.body_attributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper">

    {{{ output.standard_top_of_body_html }}}

    <div id="page" class="container pb-3">

        {{> theme_smartmind/smartmind/maintenance_content }}

    </div>
    {{> theme_smartmind/footer }}
</div>

</body>
</html>
{{#js}}
M.util.js_pending('theme_smartmind/loader');
require(['theme_smartmind/loader'], function() {
  M.util.js_complete('theme_smartmind/loader');
});
{{/js}}
