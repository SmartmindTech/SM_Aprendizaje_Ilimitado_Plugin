{{! @source: classes/output/core/course_renderer.php::enrolment_options() (override core_enrol) }}
{{!
    @template core_enrol/enrolment_options

    SmartMind enrolment page override — course landing page.
}}

{{! ===== CONTENIDO ===== }}
<div class="d-flex gap-4 flex-wrap align-items-stretch {{^hassections}}{{^hascustomfields}}justify-content-center{{/hascustomfields}}{{/hassections}}">

    {{! -- Columna principal (solo si hay contenido) -- }}
    {{#hassections}}
    <div class="flex-grow-1 d-flex flex-column" style="min-width: 0; flex-basis: 60%;">
        <div class="card flex-grow-1">
            <div class="card-header" style="background: #f8fafc;">
                <h5 class="mb-0"><i class="fa fa-list-ol me-2"></i>Contenido del curso</h5>
                <small class="text-muted">{{sectioncount}} secciones</small>
            </div>
            <ul class="p-4 flex-grow-1 d-flex flex-column justify-content-between">
                {{#sections}}
                    <li class="list-group-item d-flex align-items-center">
                        <i class="fa fa-book-open me-3 text-muted"></i>
                        <span>{{sectionname}}</span>
                    </li>
                {{/sections}}
            </ul>
        </div>

        {{#hascustomfields}}
        <div class="card mb-4">
            <div class="card-header" style="background: #f8fafc;">
                <h5 class="mb-0"><i class="fa fa-info-circle me-2"></i>Detalles del curso</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    {{#customfields}}
                        <div class="col-sm-6 mb-2">
                            <strong>{{fieldname}}:</strong> {{{fieldvalue}}}
                        </div>
                    {{/customfields}}
                </div>
            </div>
        </div>
        {{/hascustomfields}}
    </div>
    {{/hassections}}

    {{! -- Custom fields sin secciones -- }}
    {{^hassections}}
    {{#hascustomfields}}
    <div class="flex-grow-1" style="min-width: 0; flex-basis: 60%;">
        <div class="card mb-4">
            <div class="card-header" style="background: #f8fafc;">
                <h5 class="mb-0"><i class="fa fa-info-circle me-2"></i>Detalles del curso</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    {{#customfields}}
                        <div class="col-sm-6 mb-2">
                            <strong>{{fieldname}}:</strong> {{{fieldvalue}}}
                        </div>
                    {{/customfields}}
                </div>
            </div>
        </div>
    </div>
    {{/hascustomfields}}
    {{/hassections}}

    {{! ===== SIDEBAR ===== }}
    <div style="flex: 0 0 360px;">

        {{! -- Imagen + inscripcion -- }}
        <div class="card mb-4 overflow-hidden" style="box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
            {{#courseimage}}
                <img src="{{courseimage}}" alt="{{coursename}}" class="card-img-top">
            {{/courseimage}}
            <div class="card-body" style="background: #f8fafc;">
                {{#widgets}}{{{.}}}{{/widgets}}
                {{^widgets}}
                    <div class="alert alert-warning mb-2">{{message}}</div>
                    {{{continuebutton}}}
                {{/widgets}}
            </div>
        </div>

        {{! -- Info rapida -- }}
        <div class="card" style="box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span><i class="fa fa-clock me-2"></i>Inicio</span>
                        <strong>{{startdate}}</strong>
                    </li>
                    {{#hasenddate}}
                    <li class="list-group-item d-flex justify-content-between">
                        <span><i class="fa fa-flag-checkered me-2"></i>Fin</span>
                        <strong>{{enddate}}</strong>
                    </li>
                    {{/hasenddate}}
                    <li class="list-group-item d-flex justify-content-between">
                        <span><i class="fa fa-users me-2"></i>Alumnos</span>
                        <strong>{{enrolledcount}}</strong>
                    </li>
                    {{#hassections}}
                    <li class="list-group-item d-flex justify-content-between">
                        <span><i class="fa fa-list me-2"></i>Secciones</span>
                        <strong>{{sectioncount}}</strong>
                    </li>
                    {{/hassections}}
                    {{#hascontacts}}
                    {{#contacts}}
                    <li class="list-group-item d-flex justify-content-between">
                        <span><i class="fa fa-chalkboard-teacher me-2"></i>Profesor</span>
                        <strong>{{contactname}}</strong>
                    </li>
                    {{/contacts}}
                    {{/hascontacts}}
                </ul>
            </div>
        </div>
    </div>

</div>
