{{! @source: layout/drawers.php > output (region_main) }}
{{!
    @template theme_smartmind/smartmind/main_content

    SmartMind — Main content area.

    This template renders the main content region where Moodle
    injects page-specific content (blocks, course content, etc.).

    {{{ output.main_content \}\}\} is REQUIRED — do not remove it.
    Add custom HTML before or after it as needed.
}}
<div id="page-content" class="pb-3 d-print-block">
    <div id="region-main-box">
        {{#hasregionmainsettingsmenu}}
        <div id="region-main-settings-menu" class="d-print-none">
            <div> {{{ regionmainsettingsmenu }}}</div>
        </div>
        {{/hasregionmainsettingsmenu}}
        <div id="region-main">

            {{#hasregionmainsettingsmenu}}
                <div class="region_main_settings_menu_proxy"></div>
            {{/hasregionmainsettingsmenu}}
            {{{ output.course_content_header }}}
            {{#headercontent}}
                {{> core/activity_header }}
            {{/headercontent}}
            {{#overflow}}
                <div class="container-fluid tertiary-navigation">
                    <div class="navitem">
                        {{> core/url_select}}
                    </div>
                </div>
            {{/overflow}}

            {{#iscourseall}}
            <div class="section course-section main clearfix smartmind-continue-learning">
                <div class="section-item">
                    <div class="course-section-header d-flex">
                        <h3 class="h4 sectionname course-content-item d-flex align-self-stretch align-items-center mb-0">
                            {{#str}}continuelearning, theme_smartmind{{/str}}
                        </h3>
                    </div>
                    <div class="content text-muted py-3">
                        {{#str}}continuelearning_placeholder, theme_smartmind{{/str}}
                    </div>
                </div>
            </div>
            {{/iscourseall}}
            {{#isfrontpage}}
                {{! ---- CATALOGUE HEADER ---- }}
                <div class="smartmind-catalogue-header mb-3">
                    <h1 class="smartmind-catalogue-header__title">{{#str}}coursecatalogue, theme_smartmind{{/str}}</h1>
                    <p class="smartmind-catalogue-header__desc">{{#str}}catalogue_desc, theme_smartmind{{/str}}</p>
                </div>

                {{! ---- SEARCH BAR (full width) ---- }}
                <div class="smartmind-catalogue-search mb-3" data-region="smartmind-filters">
                    <div class="smartmind-catalogue-search__wrapper">
                        <i class="fa fa-search smartmind-catalogue-search__icon"></i>
                        <input type="text"
                               class="smartmind-catalogue-search__input"
                               placeholder="{{#str}}catalogue_search_placeholder, theme_smartmind{{/str}}"
                               data-action="catalogue-search"
                               autocomplete="off">
                    </div>
                </div>

                {{! ---- TYPE FILTER ROW ---- }}
                <div class="smartmind-catalogue-types mb-5" data-region="smartmind-type-badges">
                    <button class="smartmind-type-badge smartmind-type-badge--active" data-typeid="all">
                        {{#str}}catalogue_all, theme_smartmind{{/str}}
                    </button>
                    <button class="smartmind-type-badge" data-typeid="curso">
                        <span class="smartmind-type-badge__icon">📚</span> Curso
                    </button>
                    <button class="smartmind-type-badge" data-typeid="pildora">
                        <span class="smartmind-type-badge__icon">💊</span> Píldora
                    </button>
                    <button class="smartmind-type-badge" data-typeid="video">
                        <span class="smartmind-type-badge__icon">🎬</span> Video
                    </button>
                    <button class="smartmind-type-badge" data-typeid="ruta">
                        <span class="smartmind-type-badge__icon">🗺️</span> Ruta
                    </button>
                    <button class="smartmind-type-badge" data-typeid="actividad">
                        <span class="smartmind-type-badge__icon">🎯</span> Actividad
                    </button>
                    <button class="smartmind-type-badge" data-typeid="microcredencial">
                        <span class="smartmind-type-badge__icon">🏅</span> Microcredencial
                    </button>
                </div>

                {{! ---- CATEGORY FILTER BADGES ---- }}
                <div class="smartmind-catalogue-categories mb-3" data-region="smartmind-category-badges">
                    <button class="smartmind-cat-badge smartmind-cat-badge--active" data-categoryid="all">{{#str}}catalogue_all, theme_smartmind{{/str}}</button>
                    {{#coursecategories}}
                    <button class="smartmind-cat-badge" data-categoryid="{{id}}">{{name}}</button>
                    {{/coursecategories}}
                </div>

                {{! ---- RESULTS COUNT ---- }}
                {{#hasallcourses}}
                <div class="smartmind-catalogue-results mb-3">
                    <h2 class="smartmind-catalogue-results__count" data-region="catalogue-count">{{#str}}catalogue_results, theme_smartmind, {{coursecount}}{{/str}}</h2>
                </div>
                {{/hasallcourses}}

                {{! ---- COURSE CARDS GRID ---- }}
                {{#hasallcourses}}
                <div class="smartmind-frontpage-courses" data-region="smartmind-catalogue">
                    <div class="smartmind-catalogue-grid" data-region="smartmind-catalogue-grid">
                        {{#allcourses}}
                            {{> theme_smartmind/catalogue_card }}
                        {{/allcourses}}
                    </div>
                </div>
                {{/hasallcourses}}
                <div class="d-none">{{{ output.main_content }}}</div>
            {{/isfrontpage}}
            {{^isfrontpage}}
                {{#isdashboard}}
                    <div class="d-none">{{{ output.main_content }}}</div>
                {{/isdashboard}}
                {{^isdashboard}}
                    {{{ output.main_content }}}
                {{/isdashboard}}
            {{/isfrontpage}}
            {{#isdashboard}}
            <div class="catalog-dashboard">

                {{! ---- WELCOME BANNER ---- }}
                {{> theme_smartmind/dashboard/dashboard_welcome_banner }}

                {{! ---- QUICK NAVIGATION ---- }}
                {{> theme_smartmind/dashboard/dashboard_quick_nav }}

                {{! ---- SEGUIR APRENDIENDO (enrolled courses grid) ---- }}
                {{> theme_smartmind/dashboard/dashboard_enrolled_courses }}

                {{! ---- PORQUE HAS EXPLORADO ---- }}
                {{> theme_smartmind/dashboard/dashboard_rec_explored }}

                {{! ---- CATEGORY SECTIONS (custom smgp categories) ---- }}
                {{> theme_smartmind/dashboard/dashboard_category_section }}

                {{! ---- SIGUE AVANZANDO (based on completed) ---- }}
                {{> theme_smartmind/dashboard/dashboard_rec_completed }}

                {{! ---- VÍDEOS ---- }}
                {{> theme_smartmind/dashboard/dashboard_videos }}

                {{! ---- ACTIVIDADES ---- }}
                {{> theme_smartmind/dashboard/dashboard_activities }}

                {{! ---- ITINERARIOS ---- }}
                {{> theme_smartmind/dashboard/dashboard_itineraries }}

                {{! ---- RECOMENDADO PARA TI ---- }}
                {{> theme_smartmind/dashboard/dashboard_recommended_courses }}

            </div>
            {{/isdashboard}}
            {{{ output.activity_navigation }}}
            {{{ output.course_content_footer }}}

        </div>
    </div>
</div>

