{{!
    @template theme_smartmind/smartmind/user_area

    SmartMind — User navigation area (right side of top navbar).

    Contains: search box, language menu, plugin output (notifications, messages),
    company selector, user menu (avatar dropdown).
}}
<div id="usernavigation" class="smgp-topnav__user-area">
    {{# output.search_box }}
        {{{ output.search_box }}}
    {{/output.search_box}}
    {{#langmenu}}
        {{> theme_smartmind/language_menu }}
    {{/langmenu}}
    {{{ output.navbar_plugin_output }}}
    {{#hascompanyselector}}
        {{{ companyselector }}}
    {{/hascompanyselector}}
    {{#usermenu}}
        {{> core/user_menu }}
    {{/usermenu}}
</div>
