{{!
    @template theme_smartmind/navbar_left

    SmartMind — Horizontal top navbar.

    Contains: logo, primary navigation items (center), user area (right).
}}
<nav class="smgp-topnav" aria-label="{{#str}}sitemenubar, admin{{/str}}">
    {{! ---- Left: Logo ---- }}
    <div class="smgp-topnav__left">
        <a href="{{{ config.homeurl }}}" class="smgp-topnav__logo">
            <img src="{{{config.wwwroot}}}/theme/smartmind/img/smartmind.png" alt="{{sitename}}">
        </a>
    </div>

    {{! ---- Center: Navigation items ---- }}
    <div class="smgp-topnav__center">
        {{#iscompanymanager}}
            {{#companymanagernav}}
                <a href="{{{url}}}"
                   class="smgp-topnav__item {{#isactive}}smgp-topnav__item--active{{/isactive}} {{#disabled}}smgp-topnav__item--disabled{{/disabled}}"
                   data-key="{{key}}"
                   {{#disabled}}aria-disabled="true"{{/disabled}}>
                    <span class="smartmind-nav-icon" aria-hidden="true">
                        {{#smicon}}<i class="fa fa-fw {{smicon}}"></i>{{/smicon}}
                    </span>
                    <span class="smgp-topnav__item-text">{{{text}}}</span>
                </a>
            {{/companymanagernav}}
        {{/iscompanymanager}}
        {{^iscompanymanager}}
            {{#primarymoremenu}}
                {{#nodecollection}}
                    {{#children}}
                        {{^haschildren}}
                            <a href="{{{url}}}{{{action}}}"
                               class="smgp-topnav__item {{#isactive}}smgp-topnav__item--active{{/isactive}}"
                               data-key="{{key}}">
                                <span class="smartmind-nav-icon" aria-hidden="true">
                                    {{#smicon}}<i class="fa fa-fw {{smicon}}"></i>{{/smicon}}
                                    {{^smicon}}<i class="fa fa-fw fa-circle-o"></i>{{/smicon}}
                                </span>
                                <span class="smgp-topnav__item-text">{{{text}}}</span>
                            </a>
                        {{/haschildren}}
                        {{#haschildren}}
                            <div class="smgp-topnav__dropdown">
                                <a href="#"
                                   class="smgp-topnav__item {{#isactive}}smgp-topnav__item--active{{/isactive}}"
                                   data-key="{{key}}"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <span class="smartmind-nav-icon" aria-hidden="true">
                                        <i class="fa fa-fw fa-folder-o"></i>
                                    </span>
                                    <span class="smgp-topnav__item-text">{{{text}}}</span>
                                </a>
                                <div class="dropdown-menu">
                                    {{#children}}
                                        {{^divider}}
                                            <a class="dropdown-item" href="{{{url}}}{{{action}}}">{{{text}}}</a>
                                        {{/divider}}
                                        {{#divider}}<div class="dropdown-divider"></div>{{/divider}}
                                    {{/children}}
                                </div>
                            </div>
                        {{/haschildren}}
                    {{/children}}
                {{/nodecollection}}
                {{#nodearray}}
                    {{^haschildren}}
                        <a href="{{{url}}}{{{action}}}"
                           class="smgp-topnav__item {{#isactive}}smgp-topnav__item--active{{/isactive}}"
                           data-key="{{key}}">
                            <span class="smartmind-nav-icon" aria-hidden="true">
                                {{#smicon}}<i class="fa fa-fw {{smicon}}"></i>{{/smicon}}
                                {{^smicon}}<i class="fa fa-fw fa-circle-o"></i>{{/smicon}}
                            </span>
                            <span class="smgp-topnav__item-text">{{{text}}}</span>
                        </a>
                    {{/haschildren}}
                {{/nodearray}}
            {{/primarymoremenu}}
        {{/iscompanymanager}}
    </div>

    {{! ---- Right: User area ---- }}
    <div class="smgp-topnav__right">
        {{> theme_smartmind/smartmind/user_area }}
    </div>
</nav>
