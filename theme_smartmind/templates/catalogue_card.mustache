{{!
    @template theme_smartmind/catalogue_card

    Course catalogue card — Stratoos-style design.

    Context variables required for this template:
    * fullname - Course full name
    * shortname - Course short name (code)
    * categoryid - Catalogue category ID
    * categoryname - Catalogue category name
    * courseimage - URL of the course image (optional)
    * viewurl - URL to view the course
    * teachername - Name of the main instructor
    * studentcount - Number of enrolled students
    * activitycount - Number of activities / modules
    * isnew - Whether the course is new (boolean)

    Example context (json):
    {
        "fullname": "Machine Learning con Python: De Cero a Experto",
        "shortname": "ML001",
        "categoryid": "1",
        "categoryname": "Inteligencia Artificial",
        "courseimage": "",
        "viewurl": "/course/view.php?id=2",
        "teachername": "Dr. Maria Garcia",
        "studentcount": 12450,
        "activitycount": 8,
        "isnew": false
    }
}}
<div class="col" data-region="catalogue-card" data-fullname="{{fullname}}" data-categoryid="{{categoryid}}">
    <a href="{{viewurl}}" class="catalogue-card" data-category="{{categoryname}}">
        {{! ---- Image area ---- }}
        <div class="catalogue-card__image-wrap">
            {{#courseimage}}
            <img src="{{courseimage}}" class="catalogue-card__image" alt="" loading="lazy">
            {{/courseimage}}
            {{^courseimage}}
            <div class="catalogue-card__image-placeholder">
                <i class="fa fa-graduation-cap"></i>
            </div>
            {{/courseimage}}

            {{! "NUEVO" badge top-right }}
            {{#isnew}}
            <span class="catalogue-card__new-badge">{{#str}}catalogue_new, theme_smartmind{{/str}}</span>
            {{/isnew}}
        </div>

        {{! ---- Card body ---- }}
        <div class="catalogue-card__body">
            {{#categoryname}}
            <span class="catalogue-card__category" data-cat="{{categoryname}}">{{categoryname}}</span>
            {{/categoryname}}
            <h3 class="catalogue-card__title">{{fullname}}</h3>
            {{#teachername}}
            <span class="catalogue-card__author">{{teachername}}</span>
            {{/teachername}}
            <div class="catalogue-card__meta">
                {{#activitycount}}
                <span class="catalogue-card__meta-item">
                    <i class="fa fa-clock-o"></i> {{activitycount}} {{#str}}catalogue_modules, theme_smartmind{{/str}}
                </span>
                {{/activitycount}}
                {{#studentcount}}
                <span class="catalogue-card__meta-item">
                    <i class="fa fa-users"></i> {{studentcount}}
                </span>
                {{/studentcount}}
            </div>
        </div>
    </a>
</div>
