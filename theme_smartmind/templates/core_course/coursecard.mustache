{{!
    @template core_course/coursecard

    SmartMind override — Course card (used in course listings, recentlyaccessedcourses, etc.).
    Original: course/templates/coursecard.mustache

    Shows graduation cap placeholder when no real course image exists.
}}
<div class="card course-card" role="listitem"
    data-region="course-content"
    data-course-id="{{{id}}}"
    data-courseimage="{{{courseimage}}}">
    <a href="{{viewurl}}" tabindex="-1" class="text-decoration-none">
        <div class="card-img-top course-card__image-wrapper" style="display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#f0f0f0,#e0e0e0);">
            <div class="course-card__image-placeholder" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;">
                <i class="fa fa-graduation-cap" style="font-size:2.5rem;color:#b2bec3;"></i>
            </div>
        </div>
    </a>
    <div class="card-body pe-1 course-info-container" id="course-info-container-{{id}}-{{uniqid}}">
        <div class="d-flex align-items-start">
            <div class="w-100 text-truncate">
                {{#showshortname}}
                    <div class="text-muted muted d-flex mb-1 flex-wrap">
                        <span class="visually-hidden">
                            {{#str}}aria:courseshortname, core_course{{/str}}
                        </span>
                        <div>
                            {{{shortname}}}
                        </div>
                    </div>
                {{/showshortname}}
                <a href="{{viewurl}}" class="aalink coursename me-2 mb-1">
                    {{> core_course/favouriteicon }}
                    <span class="visually-hidden">
                        {{#str}}aria:coursename, core_course{{/str}}
                    </span>
                    {{$coursename}}{{/coursename}}
                </a>
                <div class="text-muted muted d-flex flex-wrap">
                    {{$coursecategory}}{{/coursecategory}}
                </div>
                {{^visible}}
                    <div class="d-flex flex-wrap">
                        <span class="badge bg-info text-white">{{#str}} hiddenfromstudents {{/str}}</span>
                    </div>
                {{/visible}}
            </div>
        </div>
    </div>
    <div class="d-flex align-items-start">
        {{$progress}}{{/progress}}
        {{$menu}}{{/menu}}
    </div>
</div>
{{#js}}
require(['jquery'], function($) {
    var card = $('[data-course-id="{{{id}}}"].course-card');
    var src = card.attr('data-courseimage');
    if (src && !src.startsWith('data:')) {
        card.find('.course-card__image-wrapper').html(
            '<img src="' + src + '" class="course-card__image" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">'
        );
    }
});
{{/js}}
