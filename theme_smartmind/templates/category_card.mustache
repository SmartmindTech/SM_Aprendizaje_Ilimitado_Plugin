{{! @source: layout/drawers.php > coursecategories array }}
{{!
    @template theme_smartmind/category_card

    Category card for the course catalogue.
    Shows a tag-based category that groups courses.

    Context variables required for this template:
    * name - Category display name
    * tag - The Moodle tag value used to filter courses
    * image - URL of the background image

    Example context (json):
    {
        "name": "Placeholder 1",
        "tag": "placeholder-1",
        "image": "/theme/smartmind/pix/categories/placeholder.jpg"
    }
}}

<div class="col" data-region="category-card" data-categoryid="{{id}}" data-url="{{image}}">
    <article class="category-card card" role="button" style="cursor: pointer;">
        <div class="category-card__image" style="background-image: url('{{image}}');">
            <div class="category-card__overlay">
                <h3 class="category-card__title">{{name}}</h3>
            </div>
        </div>
    </article>
</div>


<style>
    .category-card{
        padding: 0;
        overflow: hidden;
        border: none;
    }
    .category-card__image{
        width: 100%;
        height: 10rem;
        background-size: cover;
        background-position: top;
    }
    .category-card__overlay{
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: end;
        padding: 1rem;
    }
    .category-card__title{
        font-size: 1rem;
        color: #fff;
        margin: 0;
        text-transform: uppercase;
    }
</style>
