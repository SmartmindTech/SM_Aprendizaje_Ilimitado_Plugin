{{!
    @template theme_smartmind/secure

    Boost secure layout template.

    Context variables required for this template:
    * sitename - The name of the site
    * output - The core renderer for the page

      Example context (json):
    {
        "sitename": "Moodle",
        "output": {
            "doctype": "<!DOCTYPE html>",
            "page_title": "Test page",
            "favicon": "favicon.ico",
            "main_content": "<h1>Headings make html validators happier</h1>"
         }
    }
}}
{{> theme_smartmind/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper">

    {{{ output.standard_top_of_body_html }}}

    {{>theme_smartmind/navbar-secure}}

    <div id="page" class="container-fluid">
        {{! Secured full header }}

        {{> theme_smartmind/smartmind/secure_header }}

        {{> theme_smartmind/smartmind/secure_content }}
    </div>
    {{> theme_smartmind/smartmind/secure_footer }}
</div>


</body>
</html>
{{#js}}
M.util.js_pending('theme_smartmind/loader');
require(['theme_smartmind/loader'], function() {
    M.util.js_complete('theme_smartmind/loader');
});
{{/js}}
