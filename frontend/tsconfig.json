{
  // Nuxt 4 generates separate project tsconfigs for app, server, shared
  // and node contexts under .nuxt/. The supported root tsconfig is a
  // solution-style file that just references them — type-checking and
  // path resolution are delegated to those generated projects (which
  // already know about the app/ source layout, auto-imports, and the
  // i18n + Pinia plugins). Don't add compilerOptions or include here.
  "files": [],
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.server.json" },
    { "path": "./.nuxt/tsconfig.shared.json" },
    { "path": "./.nuxt/tsconfig.node.json" }
  ]
}
