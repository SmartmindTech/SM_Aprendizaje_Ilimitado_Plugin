# SmartMind Plugin — Developer Environment Variables
#
# Copy this file to .env and fill in the variables for your setup.
# Then run the setup script for your platform:
#   - Windows (local Moodle):       .\scripts\windows\setup.ps1
#   - Linux/WSL/Mac (local Moodle): ./scripts/linux/setup.sh
#   - Docker + Windows:             .\scripts\docker_windows\setup.ps1
#   - Docker + Linux/WSL/Mac:       ./scripts/docker_linux/setup.sh

# =============================================================================
# REQUIRED for local Moodle (scripts/windows & scripts/linux)
# =============================================================================

# Path to the Moodle installation root (the folder containing admin/, theme/, local/).
# Used by: scripts/windows/* and scripts/linux/*
# Windows example:
MOODLE_PATH=C:\MoodleWindowsInstaller-latest-500\server\moodle
# WSL/Linux example:
# MOODLE_PATH=/mnt/c/MoodleWindowsInstaller-latest-500/server/moodle

# =============================================================================
# REQUIRED for Docker (scripts/docker_windows & scripts/docker_linux)
# =============================================================================

# Docker container name running Moodle/IOMAD.
# Used by: scripts/docker_windows/* and scripts/docker_linux/*
# Find it with: docker ps --format '{{.Names}}'
DOCKER_CONTAINER=iomad_app

# If docker requires sudo, add your user to the docker group instead:
#   sudo usermod -aG docker $USER
# Then log out and back in. No sudo needed after that.

# =============================================================================
# OPTIONAL
# =============================================================================

# Your development branch name (used by git-pull to pull from dev).
# Examples: devPaulo, devDiego, devAntonio
GIT_BRANCH=devPaulo

# Update channel selector.
#
#   UPDATE_BRANCH=latest  (PRODUCTION DEFAULT)
#       Moodle fetches the update.xml asset from the GitHub release tagged
#       "latest" by CI. URL:
#         https://github.com/SmartmindTech/SM_Aprendizaje_Ilimitado_Plugin/releases/latest/download/update.xml
#       Cache TTL ~1 minute → "Check for updates" reflects new releases within
#       ~1 min of the CI run finishing, regardless of source branch.
#
#   UPDATE_BRANCH=<branch name>  (DEV / branch pinning)
#       Moodle fetches update.xml from the specified branch's raw file:
#         https://raw.githubusercontent.com/SmartmindTech/SM_Aprendizaje_Ilimitado_Plugin/<branch>/update.xml
#       Cache TTL ~5 minutes. Useful to pin a Moodle to a specific dev branch
#       during development. Examples: main, dev, testnuxt, devPaulo.
UPDATE_BRANCH=testnuxt

# =============================================================================
# FRONTEND SPA (frontend/.env is auto-read by Nuxt)
# =============================================================================

# Moodle URL for the Nuxt dev proxy (used by: npm run dev in frontend/).
# Paulo uses 8081, others may use 8080.
# This is also copied to frontend/.env by the setup script.
MOODLE_URL=http://localhost:8080

# Vue SPA hot-reload dev mode.
#
# Set SPA_DEV=1 to make pages/spa.php fetch HTML from a running Nuxt dev
# server instead of serving the pre-built frontend_dist/. Edits to
# .vue/.scss/.json sources reflect in the browser instantly via Vite HMR
# while you keep using the Moodle URL (e.g. http://localhost:8081/...).
#
# Workflow:
#   Terminal 1: cd frontend && npm run dev
#   Terminal 2: ./scripts/docker_linux/watch.sh   (PHP/lang sync)
#   Browser:    http://localhost:8081/local/sm_graphics_plugin/pages/spa.php
#
# Disable (SPA_DEV=0 or unset) for normal static frontend_dist serving.
SPA_DEV=0
SPA_DEV_PORT=4173
