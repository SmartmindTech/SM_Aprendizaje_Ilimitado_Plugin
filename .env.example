# SmartMind Plugin — Developer Environment Variables
#
# Copy this file to .env and fill in the variables for your setup.
# Then run the setup script for your platform:
#   - Windows (local Moodle):       .\scripts\windows\setup.ps1
#   - Linux/WSL/Mac (local Moodle): ./scripts/linux/setup.sh
#   - Docker + Windows:             .\scripts\docker_windows\setup.ps1
#   - Docker + Linux/WSL/Mac:       ./scripts/docker_linux/setup.sh

# =============================================================================
# REQUIRED for local Moodle (scripts/windows & scripts/linux)
# =============================================================================

# Path to the Moodle installation root (the folder containing admin/, theme/, local/).
# Used by: scripts/windows/* and scripts/linux/*
# Windows example:
MOODLE_PATH=C:\MoodleWindowsInstaller-latest-500\server\moodle
# WSL/Linux example:
# MOODLE_PATH=/mnt/c/MoodleWindowsInstaller-latest-500/server/moodle

# =============================================================================
# REQUIRED for Docker (scripts/docker_windows & scripts/docker_linux)
# =============================================================================

# Docker container name running Moodle/IOMAD.
# Used by: scripts/docker_windows/* and scripts/docker_linux/*
# Find it with: docker ps --format '{{.Names}}'
DOCKER_CONTAINER=iomad_app

# If docker requires sudo, add your user to the docker group instead:
#   sudo usermod -aG docker $USER
# Then log out and back in. No sudo needed after that.

# =============================================================================
# OPTIONAL
# =============================================================================

# Your development branch name (used by git-pull to pull from dev).
# Examples: devPaulo, devDiego, devAntonio
GIT_BRANCH=devPaulo

# =============================================================================
# GEMINI AI (optional — auto-translates learning objectives)
# =============================================================================

# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-4b-it
