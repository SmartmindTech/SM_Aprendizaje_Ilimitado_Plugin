{{!
    Template: local_sm_graphics_plugin/companylimits_page

    Admin page for managing maximum student limits per company.

    Context variables (set in pages/companylimits.php):
    - heading, help, sesskey, actionurl
    - companies: array (companyid, companyname, shortname, studentcount, maxstudents, unlimited, limitreached)
    - th_company, th_shortname, th_students, th_maxlimit, th_status
    - save_label, unlimited_label, ok_label, full_label
}}
<div class="sm-companylimits p-4">
    <h2 class="mb-2">{{heading}}</h2>
    <p class="text-muted mb-4">{{help}}</p>

    {{#hascompanies}}
        <form method="post" action="{{actionurl}}">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>{{th_company}}</th>
                            <th>{{th_shortname}}</th>
                            <th class="text-center">{{th_students}}</th>
                            <th class="text-center">{{th_maxlimit}}</th>
                            <th class="text-center">{{th_status}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#companies}}
                            <tr>
                                <td>{{companyname}}</td>
                                <td class="text-muted">{{shortname}}</td>
                                <td class="text-center">{{studentcount}}</td>
                                <td class="text-center" style="width:140px">
                                    <input type="number"
                                           name="limits[{{companyid}}]"
                                           value="{{maxstudents}}"
                                           min="0"
                                           class="form-control form-control-sm text-center"
                                    >
                                </td>
                                <td class="text-center">
                                    {{#unlimited}}
                                        <span class="badge bg-secondary">{{unlimited_label}}</span>
                                    {{/unlimited}}
                                    {{^unlimited}}
                                        {{#limitreached}}
                                            <span class="badge bg-danger">{{full_label}}</span>
                                        {{/limitreached}}
                                        {{^limitreached}}
                                            <span class="badge bg-success">{{ok_label}}</span>
                                        {{/limitreached}}
                                    {{/unlimited}}
                                </td>
                            </tr>
                        {{/companies}}
                    </tbody>
                </table>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-save"></i> {{save_label}}
            </button>
        </form>
    {{/hascompanies}}

    {{^hascompanies}}
        <div class="alert alert-info">No companies found.</div>
    {{/hascompanies}}
</div>
