{{!
    @template local_sm_graphics_plugin/mycourses_page

    My Courses page — list of enrolled and completed courses with progress.
}}
<div class="smgp-mycourses">
    {{! ---- HEADER ---- }}
    <div class="smartmind-catalogue-header mb-4">
        <span class="smartmind-catalogue-header__eyebrow">{{#str}}page_eyebrow, local_sm_graphics_plugin{{/str}}</span>
        <h1 class="smartmind-catalogue-header__title">{{#str}}mycourses_title, local_sm_graphics_plugin{{/str}}</h1>
        <p class="smartmind-catalogue-header__desc">{{#str}}mycourses_desc, local_sm_graphics_plugin{{/str}}</p>
    </div>

    {{! ---- FILTER BADGES ---- }}
    <div class="smgp-mycourses__filters mb-4" data-region="mycourses-filters">
        <button class="smartmind-badge smartmind-badge--active" data-filter="inprogress">{{#str}}mycourses_inprogress, local_sm_graphics_plugin{{/str}}</button>
        <button class="smartmind-badge" data-filter="completed">{{#str}}mycourses_completed, local_sm_graphics_plugin{{/str}}</button>
        <button class="smartmind-badge" data-filter="all">{{#str}}mycourses_all, local_sm_graphics_plugin{{/str}}</button>
    </div>

    {{! ---- COURSE LIST ---- }}
    <div class="smgp-mycourses__list" data-region="mycourses-list">
        {{#enrolledcourses}}
        <div class="smgp-mycourses__row" data-status="inprogress">
            <div class="smgp-mycourses__icon-area">
                {{#courseimage}}
                <img src="{{courseimage}}" alt="" loading="lazy">
                {{/courseimage}}
                {{^courseimage}}
                <i class="fa fa-graduation-cap"></i>
                {{/courseimage}}
            </div>
            <div class="smgp-mycourses__info">
                <h3 class="smgp-mycourses__course-name">{{fullname}}</h3>
                <span class="smgp-mycourses__meta">{{shortname}}{{#activitycount}} · {{activitycount}} {{#str}}catalogue_modules, local_sm_graphics_plugin{{/str}}{{/activitycount}}{{#categoryname}} · {{categoryname}}{{/categoryname}}</span>
                {{#hasprogress}}
                <div class="smgp-mycourses__progress-bar">
                    <div class="smgp-mycourses__progress-fill" style="width: {{progress}}%"></div>
                </div>
                <span class="smgp-mycourses__progress-text">{{progress}}% {{#str}}mycourses_completed_label, local_sm_graphics_plugin{{/str}} · {{#str}}mycourses_resource, local_sm_graphics_plugin{{/str}} {{completed_activities}} {{#str}}mycourses_of, local_sm_graphics_plugin{{/str}} {{total_activities}}</span>
                {{/hasprogress}}
            </div>
            <div class="smgp-mycourses__action">
                <a href="{{continueurl}}" class="smgp-mycourses__btn">{{#str}}mycourses_continue, local_sm_graphics_plugin{{/str}}</a>
                <span class="smgp-mycourses__status smgp-mycourses__status--inprogress">{{#str}}mycourses_inprogress, local_sm_graphics_plugin{{/str}}</span>
            </div>
        </div>
        {{/enrolledcourses}}

        {{#completedcourses}}
        <div class="smgp-mycourses__row" data-status="completed">
            <div class="smgp-mycourses__icon-area smgp-mycourses__icon-area--completed">
                {{#courseimage}}
                <img src="{{courseimage}}" alt="" loading="lazy">
                {{/courseimage}}
                {{^courseimage}}
                <i class="fa fa-graduation-cap"></i>
                {{/courseimage}}
            </div>
            <div class="smgp-mycourses__info">
                <h3 class="smgp-mycourses__course-name">{{fullname}}</h3>
                <span class="smgp-mycourses__meta">{{shortname}}{{#activitycount}} · {{activitycount}} {{#str}}catalogue_modules, local_sm_graphics_plugin{{/str}}{{/activitycount}}{{#categoryname}} · {{categoryname}}{{/categoryname}}</span>
                <div class="smgp-mycourses__progress-bar">
                    <div class="smgp-mycourses__progress-fill smgp-mycourses__progress-fill--completed" style="width: 100%"></div>
                </div>
                <span class="smgp-mycourses__progress-text">100% {{#str}}mycourses_completed_label, local_sm_graphics_plugin{{/str}} · {{#str}}mycourses_resource, local_sm_graphics_plugin{{/str}} {{completed_activities}} {{#str}}mycourses_of, local_sm_graphics_plugin{{/str}} {{total_activities}}</span>
            </div>
            <div class="smgp-mycourses__action">
                <a href="{{viewurl}}" class="smgp-mycourses__btn smgp-mycourses__btn--completed">{{#str}}mycourses_review, local_sm_graphics_plugin{{/str}}</a>
                <span class="smgp-mycourses__status smgp-mycourses__status--completed">{{#str}}mycourses_completed, local_sm_graphics_plugin{{/str}}</span>
            </div>
        </div>
        {{/completedcourses}}

        {{^hasallcourses}}
        <div class="text-muted text-center py-5">
            {{#str}}mycourses_empty, local_sm_graphics_plugin{{/str}}
        </div>
        {{/hasallcourses}}
    </div>
</div>

{{#js}}
require(['jquery'], function($) {
    var filters = $('[data-region="mycourses-filters"]');
    var rows = $('[data-region="mycourses-list"] .smgp-mycourses__row');

    filters.on('click', '.smartmind-badge', function() {
        filters.find('.smartmind-badge').removeClass('smartmind-badge--active');
        $(this).addClass('smartmind-badge--active');

        var filter = $(this).data('filter');
        rows.each(function() {
            var status = $(this).data('status');
            if (filter === 'all' || status === filter) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });
});
{{/js}}
