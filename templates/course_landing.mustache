{{!
    Course landing page template.

    @package    local_sm_graphics_plugin
    @copyright  2026 SmartMind Technologies
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}

<div class="smgp-landing" data-courseid="{{courseid}}">
    <h2 class="smgp-landing__heading">
        <i class="icon-notebook-text"></i>
        {{#str}}landing_program_content, local_sm_graphics_plugin{{/str}}
    </h2>

    {{#hassummary}}
    <div class="smgp-landing__summary">
        {{{coursesummary}}}
    </div>
    {{/hassummary}}

    <div class="smgp-landing__body">
        {{! Left column: program content }}
        <div class="smgp-landing__main">
            <div class="smgp-landing__sections">
                {{#sections}}
                <div class="smgp-landing__section smgp-landing__section--expanded">
                    <div class="smgp-landing__section-header" role="button" tabindex="0"
                         aria-expanded="true">
                        <div class="smgp-landing__section-title">
                            <span class="smgp-landing__section-name">{{name}}</span>
                            <span class="smgp-landing__section-count">{{activity_count}} {{#str}}landing_modules, local_sm_graphics_plugin{{/str}}</span>
                        </div>
                        <i class="icon-chevron-down smgp-landing__chevron"></i>
                    </div>
                    {{#hasactivities}}
                    <div class="smgp-landing__section-body">
                        <ul class="smgp-landing__activities">
                            {{#activities}}
                            <li class="smgp-landing__activity" data-cmid="{{cmid}}">
                                <i class="{{iconclass}} smgp-landing__activity-icon"></i>
                                <span class="smgp-landing__activity-name">{{name}}</span>
                                <span class="smgp-landing__activity-type">{{modtypelabel}}</span>
                                {{#canedit}}
                                <button class="smgp-landing__delete-btn" data-cmid="{{cmid}}" title="{{#str}}landing_delete_activity, local_sm_graphics_plugin{{/str}}">
                                    <i class="icon-circle-x"></i>
                                </button>
                                {{/canedit}}
                            </li>
                            {{/activities}}
                        </ul>
                    </div>
                    {{/hasactivities}}
                    {{#canedit}}
                    <button class="smgp-landing__add-btn" data-sectionnum="{{number}}" data-courseid="{{courseid}}">
                        <i class="icon-circle-plus"></i> {{#str}}landing_add_activity, local_sm_graphics_plugin{{/str}}
                    </button>
                    {{/canedit}}
                </div>
                {{/sections}}
            </div>
        </div>

        {{! Right column: course info sidebar }}
        <div class="smgp-landing__sidebar">
            {{#hasimage}}
            <div class="smgp-landing__image">
                <img src="{{courseimageurl}}" alt="{{coursename}}" />
            </div>
            {{/hasimage}}

            <div class="smgp-landing__info-card">
                <div class="smgp-landing__info-header">
                    <h3 class="smgp-landing__info-title">
                        {{#str}}landing_course_info, local_sm_graphics_plugin{{/str}}
                    </h3>
                    {{#is_enrolled_real}}
                    <span class="smgp-landing__enrolled-badge">
                        <i class="icon-check-circle"></i>
                        {{#str}}landing_enrolled_badge, local_sm_graphics_plugin{{/str}}
                    </span>
                    {{/is_enrolled_real}}
                </div>

                <div class="smgp-landing__info-rows">
                    {{#has_course_category}}
                    <div class="smgp-landing__info-row">
                        <i class="icon-bookmark"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_category, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{course_category}}</span>
                    </div>
                    {{/has_course_category}}

                    <div class="smgp-landing__info-row">
                        <i class="icon-gauge"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_level, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{level_label}}</span>
                    </div>

                    <div class="smgp-landing__info-row">
                        <i class="icon-layout-grid"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_modules, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{total_activities}}</span>
                    </div>

                    <div class="smgp-landing__info-row">
                        <i class="icon-list-checks"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_sections, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{section_count}}</span>
                    </div>

                    {{#has_duration}}
                    <div class="smgp-landing__info-row">
                        <i class="icon-clock"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_duration, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{duration_hours}}h</span>
                    </div>
                    {{/has_duration}}

                    <div class="smgp-landing__info-row">
                        <i class="icon-languages"></i>
                        <span class="smgp-landing__info-label">{{#str}}landing_language, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{language}}</span>
                    </div>

                    {{#has_smartmind_code}}
                    <div class="smgp-landing__info-row">
                        <i class="icon-qr-code"></i>
                        <span class="smgp-landing__info-label">{{#str}}smartmind_code, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{smartmind_code}}</span>
                    </div>
                    {{/has_smartmind_code}}

                    {{#has_sepe}}
                    <div class="smgp-landing__info-row">
                        <i class="icon-file-code"></i>
                        <span class="smgp-landing__info-label">{{#str}}sepe_code, local_sm_graphics_plugin{{/str}}</span>
                        <span class="smgp-landing__info-value">{{sepe_code}}</span>
                    </div>
                    {{/has_sepe}}
                </div>
            </div>

            {{! Enrolled user: progress + next activity + start/continue }}
            {{#is_enrolled_real}}
            <div class="smgp-landing__enrolled-info">
                {{#has_next_activity}}
                <div class="smgp-landing__info-row">
                    <i class="icon-arrow-right-circle"></i>
                    <span class="smgp-landing__info-label">{{#str}}landing_next_activity, local_sm_graphics_plugin{{/str}}</span>
                    <span class="smgp-landing__info-value">{{next_activity_name}}</span>
                </div>
                {{/has_next_activity}}

                <div class="smgp-landing__progress-section">
                    <span class="smgp-landing__progress-label">{{#str}}gradescerts_progress, local_sm_graphics_plugin{{/str}}</span>
                    <div class="progress smgp-landing__progress-bar">
                        <div class="progress-bar" role="progressbar" style="width: {{progress}}%"
                             aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <span class="smgp-landing__progress-pct">{{progress}}%</span>
                </div>
            </div>
            {{/is_enrolled_real}}

            <div class="smgp-landing__action">
                {{#is_enrolled_real}}
                    {{#has_started}}
                    <a href="{{course_view_url}}" class="smgp-landing__btn smgp-landing__btn--primary">
                        <i class="icon-play"></i>
                        {{#str}}landing_continue, local_sm_graphics_plugin{{/str}}
                    </a>
                    {{/has_started}}
                    {{^has_started}}
                    <a href="{{course_view_url}}" class="smgp-landing__btn smgp-landing__btn--primary">
                        <i class="icon-circle-play"></i>
                        {{#str}}landing_start, local_sm_graphics_plugin{{/str}}
                    </a>
                    {{/has_started}}
                    <button type="button" class="smgp-landing__btn smgp-landing__btn--danger" id="smgp-unenrol-btn">
                        <i class="icon-log-out"></i>
                        {{#str}}landing_unenrol, local_sm_graphics_plugin{{/str}}
                    </button>
                {{/is_enrolled_real}}
                {{^is_enrolled_real}}
                    {{#is_enrolled}}
                    <a href="{{course_view_url}}" class="smgp-landing__btn smgp-landing__btn--primary">
                        <i class="icon-circle-play"></i>
                        {{#str}}landing_view_course, local_sm_graphics_plugin{{/str}}
                    </a>
                    {{/is_enrolled}}
                    {{^is_enrolled}}
                    <button type="button" class="smgp-landing__btn smgp-landing__btn--primary"
                            id="smgp-landing-enrol" data-courseid="{{courseid}}">
                        <i class="icon-user-plus"></i>
                        {{#str}}landing_enrol, local_sm_graphics_plugin{{/str}}
                    </button>
                    {{/is_enrolled}}
                {{/is_enrolled_real}}
            </div>
            {{#canedit}}
            <div class="smgp-landing__action" style="margin-top: 0.75rem;">
                <a href="{{edit_course_url}}" class="smgp-landing__btn smgp-landing__btn--secondary">
                    <i class="icon-square-pen"></i>
                    {{#str}}landing_edit, local_sm_graphics_plugin{{/str}}
                </a>
            </div>
            {{/canedit}}
            </div>

            {{! Unenrol confirmation modal }}
            {{#is_enrolled_real}}
            <div id="smgp-unenrol-modal" class="smgp-modal" style="display:none;">
                <div class="smgp-modal__backdrop"></div>
                <div class="smgp-modal__card">
                    <div class="smgp-modal__header">
                        <h3>{{#str}}landing_unenrol_confirm_title, local_sm_graphics_plugin{{/str}}</h3>
                        <button class="smgp-modal__close" id="smgp-unenrol-close"><i class="icon-x"></i></button>
                    </div>
                    <div class="smgp-modal__body">
                        <p>{{#str}}landing_unenrol_confirm, local_sm_graphics_plugin{{/str}}</p>
                    </div>
                    <div class="smgp-modal__footer">
                        <button class="btn btn-secondary" id="smgp-unenrol-cancel">{{#str}}landing_cancel, local_sm_graphics_plugin{{/str}}</button>
                        <button class="btn btn-danger" id="smgp-unenrol-confirm" data-courseid="{{courseid}}">
                            <i class="icon-log-out"></i>
                            {{#str}}landing_unenrol, local_sm_graphics_plugin{{/str}}
                        </button>
                    </div>
                </div>
            </div>
            {{/is_enrolled_real}}
        </div>
    </div>
</div>

{{! Quick-add modal for Genially and Video activities }}
{{#canedit}}
<div id="smgp-genially-modal" class="smgp-modal" style="display:none;">
    <div class="smgp-modal__backdrop"></div>
    <div class="smgp-modal__card">
        <div class="smgp-modal__header">
            <h3><i class="icon-presentation" style="color:#f97316;margin-right:0.5rem;"></i> Genially</h3>
            <button class="smgp-modal__close" id="smgp-genially-close"><i class="icon-x"></i></button>
        </div>
        <div class="smgp-modal__body">
            <div class="mb-3">
                <label for="smgp-genially-name">{{#str}}landing_activity_name, local_sm_graphics_plugin{{/str}}</label>
                <input type="text" id="smgp-genially-name" class="form-control" placeholder="My activity">
            </div>

            {{! Video tabs: URL vs Upload — hidden for Genially }}
            <div id="smgp-video-tabs" class="smgp-video-tabs mb-3" style="display:none;">
                <button type="button" class="smgp-video-tabs__tab active" id="smgp-video-tab-url">
                    <i class="icon-link"></i> URL
                </button>
                <button type="button" class="smgp-video-tabs__tab" id="smgp-video-tab-upload">
                    <i class="icon-upload"></i> {{#str}}landing_video_upload, local_sm_graphics_plugin{{/str}}
                </button>
            </div>

            <div class="mb-3" id="smgp-genially-url-group">
                <label for="smgp-genially-url">{{#str}}landing_activity_url, local_sm_graphics_plugin{{/str}}</label>
                <input type="url" id="smgp-genially-url" class="form-control" placeholder="https://view.genial.ly/...">
                <small class="text-muted smgp-genially-url-hint">{{#str}}landing_genially_url_hint, local_sm_graphics_plugin{{/str}}</small>
            </div>

            <div class="mb-3" id="smgp-genially-upload-group" style="display:none;">
                <div class="smgp-upload-zone" id="smgp-upload-zone">
                    <input type="file" id="smgp-upload-input" accept="video/*,.mp4,.webm,.ogg,.mov,.avi,.mkv" style="display:none;">
                    <i class="icon-cloud-upload smgp-upload-zone__icon"></i>
                    <p class="smgp-upload-zone__text">{{#str}}landing_video_upload_hint, local_sm_graphics_plugin{{/str}}</p>
                    <p class="smgp-upload-zone__file" id="smgp-upload-filename" style="display:none;"></p>
                </div>
            </div>
        </div>
        <div class="smgp-modal__footer">
            <button class="btn btn-secondary" id="smgp-genially-cancel">{{#str}}landing_cancel, local_sm_graphics_plugin{{/str}}</button>
            <button class="btn btn-primary" id="smgp-genially-save">{{#str}}landing_save, local_sm_graphics_plugin{{/str}}</button>
        </div>
        <input type="hidden" id="smgp-genially-sectionnum" value="0">
    </div>
</div>
{{/canedit}}
