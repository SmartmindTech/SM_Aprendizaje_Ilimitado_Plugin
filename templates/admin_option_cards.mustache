{{!
    Template: local_sm_graphics_plugin/admin_option_cards

    Reusable grid of equal-size administration option cards.
    Use this partial wherever a management section needs to display
    a set of action links (user management, course management, etc.).

    Context variables:
    - options: array  List of option objects, each with:
        - url:         string  Destination URL
        - icon:        string  FontAwesome icon class (e.g. fa-user-plus)
        - title:       string  Card title
        - description: string  Card description text
}}
<div class="sm-admin-cards">
    {{#options}}
        {{#disabled}}
            <div class="card shadow-sm sm-admin-card sm-admin-card--disabled">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                    <i class="fa {{icon}} fa-2x mb-2 text-muted"></i>
                    <h6 class="card-title mb-1 text-muted">{{title}}</h6>
                    <p class="card-text text-muted small mb-0">{{description}}</p>
                </div>
            </div>
        {{/disabled}}
        {{^disabled}}
            <a href="{{url}}" class="card text-decoration-none shadow-sm sm-admin-card">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                    <i class="fa {{icon}} fa-2x mb-2 text-primary"></i>
                    <h6 class="card-title mb-1">{{title}}</h6>
                    <p class="card-text text-muted small mb-0">{{description}}</p>
                </div>
            </a>
        {{/disabled}}
    {{/options}}
</div>

<style>
    /* ===== SM Admin Option Cards — reusable component ===== */
    .sm-admin-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1rem;
        width: 100%;
    }
    @media (min-width: 992px) {
        .sm-admin-cards {
            grid-template-columns: repeat(5, 1fr);
        }
    }
    .sm-admin-card {
        border: 1px solid #dee2e6;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .sm-admin-card .card-body {
        min-height: 140px;
    }
    .sm-admin-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12) !important;
    }
    .sm-admin-card .card-title {
        color: #1a1f35;
    }
    .sm-admin-card--disabled {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
    }
</style>
