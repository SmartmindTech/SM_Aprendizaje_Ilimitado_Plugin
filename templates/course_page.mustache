{{!
    Course Page — Udemy-style course dedicated page layout.

    The main content area receives the original Moodle course content (injected by JS).
    Activity clicks in the sidebar navigate to the real Moodle URL.
    Grades tab shows actual grade data, not an iframe.

    Context variables required:
        courseid, coursename, courseshortname, coursesummary, hassummary,
        dashboardurl,
        teachercount, studentcount, activitycount, sectioncount,
        overallprogress, completedactivities, totalactivities,
        teachers (array), hasteachers,
        grades (array: name, grade, percentage, hasgrade, activitytype),
        hasgrades, coursetotal, hascoursetotal,
        sections (array), sectionsjson,
        canpost, candeleteany, isteacher, userid, userfullname
}}

<div class="smgp-course-page"
     data-courseid="{{courseid}}"
     data-sections="{{sectionsjson}}"
     data-canpost="{{#canpost}}1{{/canpost}}{{^canpost}}0{{/canpost}}"
     data-canedit="{{#isteacher}}1{{/isteacher}}{{^isteacher}}0{{/isteacher}}"
     data-candeleteany="{{#candeleteany}}1{{/candeleteany}}{{^candeleteany}}0{{/candeleteany}}"
     data-userid="{{userid}}"
     data-userfullname="{{userfullname}}">

    {{! ===== Main Body (Content + Sidebar) ===== }}
    <div class="smgp-course-body">
        {{! === Main Content Area === }}
        <div class="smgp-course-main">
            {{! ===== Breadcrumb ===== }}
            <div class="smgp-course-breadcrumb" id="smgp-course-breadcrumb">
                <span class="smgp-course-breadcrumb__link" id="smgp-breadcrumb-mycourses" data-url="{{mycoursesurl}}">
                    {{#str}}course_page_mycourses_breadcrumb, local_sm_graphics_plugin{{/str}}
                </span>
                <span class="smgp-course-breadcrumb__sep">/</span>
                <span class="smgp-course-breadcrumb__current">{{coursename}}</span>
            </div>
            {{! Single activity content loaded via AJAX }}
            <div class="smgp-course-content" id="smgp-course-content-area">
                <div class="smgp-course-content__placeholder">
                    <i class="bi bi-collection-play"></i>
                    <p>{{#str}}course_page_select_activity, local_sm_graphics_plugin{{/str}}</p>
                </div>
            </div>

            {{! Activity Navigation }}
            <div class="smgp-course-nav">
                <button class="smgp-course-nav__btn smgp-course-nav__prev" id="smgp-nav-prev" disabled>
                    <i class="bi bi-chevron-left"></i>
                    <span>{{#str}}course_page_prev, local_sm_graphics_plugin{{/str}}</span>
                </button>
                <div class="smgp-course-nav__center">
                    <div class="smgp-course-progress-bar" id="smgp-course-progress-bar">
                        <div class="smgp-course-progress-bar__track">
                            <div class="smgp-course-progress-bar__fill" id="smgp-progress-fill" style="width:0%"></div>
                            <div class="smgp-course-progress-bar__cursor" id="smgp-progress-cursor" style="left:0%"></div>
                        </div>
                    </div>
                    <div class="smgp-course-nav__item-counter" id="smgp-activity-item-counter" style="display:none;"></div>
                </div>
                <button class="smgp-course-nav__btn smgp-course-nav__next" id="smgp-nav-next" disabled>
                    <span>{{#str}}course_page_next, local_sm_graphics_plugin{{/str}}</span>
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>

            {{! Activity Info (below navigation bar) }}
            <div class="smgp-course-activity-info" id="smgp-course-activity-info" style="display:none;">
                <h2 class="smgp-course-activity-info__title" id="smgp-activity-info-title"></h2>
                <p class="smgp-course-activity-info__meta" id="smgp-activity-info-meta"></p>
            </div>

            {{! ===== Tabs Section (hidden — uncomment to restore) ===== }}
            <div class="smgp-course-tabs" style="display:none;"></div>
        </div>

        {{! === Module Content Sidebar (flat list) === }}
        <aside class="smgp-course-sidebar" id="smgp-course-sidebar">
            <div class="smgp-course-sidebar__header">
                <span class="smgp-course-sidebar__title">
                    {{#str}}course_page_module_content, local_sm_graphics_plugin{{/str}}
                </span>
                <span class="smgp-course-sidebar__count">
                    <span id="smgp-sidebar-completed">{{completedactivities}}</span>/{{totalactivities}}
                </span>
            </div>

            <div class="smgp-course-sidebar__list" id="smgp-sidebar-list">
                {{#sections}}
                    {{#activities}}
                        {{^isforum}}
                        {{^islabel}}
                        <div class="smgp-course-activity{{#iscomplete}} smgp-course-activity--complete{{/iscomplete}}"
                             data-cmid="{{cmid}}" data-url="{{url}}" data-modname="{{modname}}"
                             data-name="{{name}}" data-iconclass="{{iconclass}}" data-index="{{index}}"
                             data-sectionname="{{sectionname}}" data-sectionindex="{{sectionindex}}"
                             data-resourceindex="{{resourceindex}}" data-sectiontotalcount="{{sectiontotalcount}}">
                            <div class="smgp-course-activity__icon-box">
                                <i class="{{iconclass}}"></i>
                            </div>
                            <div class="smgp-course-activity__text">
                                <p class="smgp-course-activity__name">{{name}}</p>
                                <span class="smgp-course-activity__duration" data-cmid="{{cmid}}"></span>
                            </div>
                            <div class="smgp-course-activity__completion">
                                {{#iscomplete}}
                                    <i class="bi bi-check-circle-fill smgp-course-activity__check"></i>
                                {{/iscomplete}}
                                {{^iscomplete}}
                                    <svg class="smgp-activity-ring" viewBox="0 0 20 20">
                                        <circle class="smgp-activity-ring__bg" cx="10" cy="10" r="7" fill="none" stroke-width="2"/>
                                        <circle class="smgp-activity-ring__fill" cx="10" cy="10" r="7" fill="none" stroke-width="2"
                                                stroke-dasharray="43.98" stroke-dashoffset="43.98"/>
                                    </svg>
                                {{/iscomplete}}
                            </div>
                        </div>
                        {{/islabel}}
                        {{/isforum}}
                    {{/activities}}
                {{/sections}}
            </div>
        </aside>

        {{! Sidebar Toggle }}
        <button class="smgp-course-sidebar__toggle" id="smgp-sidebar-toggle"
                title="{{#str}}course_page_collapse_sidebar, local_sm_graphics_plugin{{/str}}">
            <i class="bi bi-chevron-right"></i>
        </button>
    </div>

    {{! Floating Focus Mode Button }}
    <button class="smgp-course-focus-btn" id="smgp-course-focus-btn"
            title="{{#str}}focus_mode, local_sm_graphics_plugin{{/str}}" type="button">
        <i class="bi bi-arrows-fullscreen"></i>
    </button>
</div>
