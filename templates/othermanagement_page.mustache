{{!
    Template: local_sm_graphics_plugin/othermanagement_page

    Categories displayed as cards. Clicking one expands its sub-options
    (also as cards) below the category row. Accordion behaviour: only one
    category open at a time.

    Context variables (set in pages/othermanagement.php or iomaddashboard.php):
    - heading:     string  Page heading
    - companyname: string  (optional) Company name for subtitle
    - categories:  array   Each element has:
        - key:     string  Unique id (e.g. "companies")
        - icon:    string  FontAwesome class
        - title:   string  Category label
        - options: array   Sub-option cards (url, icon, title, description)
}}
<div class="sm-othermanagement p-4 w-100">
    <h2 class="{{#companyname}}mb-1{{/companyname}}{{^companyname}}mb-4{{/companyname}}">{{heading}}</h2>
    {{#companyname}}
        <p class="text-muted mb-4">{{companyname}}</p>
    {{/companyname}}

    {{! ===== Category cards ===== }}
    <div class="sm-admin-cards mb-3" id="sm-othermgmt-accordion">
        {{#categories}}
            <div class="card shadow-sm sm-admin-card sm-category-toggle {{#isfirst}}active{{/isfirst}}"
                 data-bs-toggle="collapse"
                 data-bs-target="#collapse-{{key}}"
                 aria-expanded="false"
                 aria-controls="collapse-{{key}}"
                 role="button"
            >
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                    <i class="fa {{icon}} fa-2x mb-2 text-primary"></i>
                    <h6 class="card-title mb-0">{{title}}</h6>
                </div>
            </div>
        {{/categories}}
    </div>

    {{! ===== Collapsible sub-option panels ===== }}
    <div id="sm-othermgmt-panels">
        {{#categories}}
            <div class="collapse sm-category-panel" id="collapse-{{key}}" data-bs-parent="#sm-othermgmt-panels">
                <div class="p-3">
                    <h5 class="mb-3">{{title}}</h5>
                    {{> local_sm_graphics_plugin/admin_option_cards }}
                </div>
            </div>
        {{/categories}}
    </div>
</div>

<style>
    /* Force Moodle layout chain to full width. */
    #page,
    #topofscroll,
    .main-inner,
    #page-content,
    #region-main-box,
    [role="main"],
    #region-main,
    .smartmind-page-banner,
    .smartmind-page-banner__content {
        max-width: 100% !important;
        width: 100% !important;
        box-sizing: border-box !important;
    }
    .main-inner {
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }
    #page-content,
    #region-main-box,
    #region-main {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }
    .sm-othermanagement {
        width: 100%;
        max-width: 100%;
    }

    /* Category cards — clickable, cursor pointer */
    .sm-category-toggle {
        cursor: pointer;
        user-select: none;
    }
    .sm-category-toggle[aria-expanded="true"] {
        border-color: var(--bs-primary, #2e7d32);
        box-shadow: 0 0 0 2px var(--bs-primary, #2e7d32) !important;
    }

    /* Sub-option panel */
    .sm-category-panel .sm-admin-cards {
        margin-top: 0;
    }

    {{#fourcolumns}}
    /* IOMAD dashboard: 4 columns per row */
    .sm-admin-cards {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)) !important;
    }
    @media (min-width: 992px) {
        .sm-admin-cards {
            grid-template-columns: repeat(4, 1fr) !important;
        }
    }
    {{/fourcolumns}}
</style>
