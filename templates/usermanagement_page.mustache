{{!
    Template: local_sm_graphics_plugin/usermanagement_page

    Renders management option cards (single row, full width) and a
    registered-user listing for company managers.

    Context variables (set in pages/usermanagement.php):
    - heading:          string   Page heading
    - options:          array    Option cards (url, icon, title, description)
    - users:            array    User rows   (fullname, email, lastaccess, editurl)
    - hasusers:         bool     Whether there are users
    - usercount:        int      Total number of users
    - th_name:          string   Column header: Name
    - th_email:         string   Column header: Email
    - th_lastaccess:    string   Column header: Last access
    - th_actions:       string   Column header: Actions
    - userlist_heading: string   Section heading for user list
    - edit_label:       string   Label for edit button
    - nousers:          string   Message when no users
}}
<div class="sm-usermanagement p-4 w-100">

    {{! ===== Management option cards (reusable component) ===== }}
    <h2 class="mb-4">{{heading}}</h2>
    <div class="mb-5">
        {{> local_sm_graphics_plugin/admin_option_cards }}
    </div>
</div>

{{! ===== Registered users — separate container ===== }}
<div class="sm-userlist p-4 w-100">
    <h3 class="mb-3 d-flex justify-content-between align-items-center">
        <span>{{userlist_heading}}</span>
        {{#haslimit}}
            <span class="small border rounded px-2 py-1 {{#limitreached}}text-danger fw-bold border-danger{{/limitreached}}{{^limitreached}}text-dark border-secondary{{/limitreached}}">
                {{studentcount}} / {{maxstudents}}
            </span>
        {{/haslimit}}
        {{^haslimit}}
            <span class="small text-dark border border-secondary rounded px-2 py-1">{{usercount}}</span>
        {{/haslimit}}
    </h3>
    {{#limitreached}}
        <div class="alert alert-warning">
            <i class="fa fa-exclamation-triangle"></i> {{limit_reached_msg}}
        </div>
    {{/limitreached}}

    {{#hasusers}}
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle sm-usermgmt-table">
                <thead class="table-light">
                    <tr>
                        <th>{{th_name}}</th>
                        <th>{{th_email}}</th>
                        <th>{{th_lastaccess}}</th>
                        <th class="text-center">{{th_actions}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#users}}
                        <tr>
                            <td>{{fullname}}</td>
                            <td>{{email}}</td>
                            <td>{{lastaccess}}</td>
                            <td class="text-center text-nowrap">
                                <a href="{{{editurl}}}" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="fa fa-pen"></i> {{edit_label}}
                                </a>
                                <a href="{{{deleteurl}}}" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('{{delete_confirm}}');">
                                    <i class="fa fa-trash-can"></i> {{delete_label}}
                                </a>
                            </td>
                        </tr>
                    {{/users}}
                </tbody>
            </table>
        </div>
        {{{pagingbar}}}
    {{/hasusers}}

    {{^hasusers}}
        <div class="alert alert-info">{{nousers}}</div>
    {{/hasusers}}
</div>

<style>
    /* Force every wrapper in the Moodle layout chain to full width.
       Chain: #page → .main-inner → page_header / #page-content → #region-main-box → #region-main */
    #page,
    #topofscroll,
    .main-inner,
    #page-content,
    #region-main-box,
    [role="main"],
    #region-main,
    .smartmind-page-banner,
    .smartmind-page-banner__content {
        max-width: 100% !important;
        width: 100% !important;
        box-sizing: border-box !important;
    }
    .main-inner {
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }
    #page-content,
    #region-main-box,
    #region-main {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }
    .sm-usermanagement,
    .sm-userlist {
        width: 100%;
        max-width: 100%;
    }

    /* User table — full width */
    .sm-usermgmt-table {
        width: 100%;
    }
    .sm-usermgmt-table th {
        white-space: nowrap;
    }

</style>
